{
  "installCommand": "npm install && npm install --prefix node_modules @rollup/rollup-linux-x64-gnu --no-save 2>/dev/null || true",
  "buildCommand": "npm run build:web",
  "outputDirectory": "apps/web/dist",
  "rewrites": [
    { "source": "/rpc/monad", "destination": "https://testnet-rpc.monad.xyz" },
    { "source": "/upload/catbox", "destination": "https://catbox.moe/user/api.php" },
    { "source": "/create", "destination": "/index.html" },
    { "source": "/explore", "destination": "/index.html" },
    { "source": "/vault", "destination": "/index.html" },
    { "source": "/admin", "destination": "/index.html" },
    { "source": "/connect", "destination": "/index.html" },
    { "source": "/pact/:path*", "destination": "/index.html" }
  ]
}
